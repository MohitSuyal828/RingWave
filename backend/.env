# ── Add these two lines to your existing .env and .env.example ──────────────
# (Do not overwrite your existing JWT_SECRET, DB_PASSWORD, etc. — only add these.)

# Access token (JWT) lifetime. Short by design — see refresh token system docs.
ACCESS_TOKEN_EXPIRES_IN=15m

# Refresh token lifetime, in days. Used to compute expires_at when a new
# refresh_tokens row is created at login.
REFRESH_TOKEN_EXPIRES_IN_DAYS=7